# Copy this file to .env and fill in your values
# .env is gitignored — never commit the real .env

# Database (Docker Compose default)
DATABASE_URL=postgresql+asyncpg://acqcopilot:devpassword@localhost:5433/acqcopilot
REDIS_URL=redis://localhost:6379/0

# LLM API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# Government Data APIs
# One api.data.gov key covers: Per Diem, SAM.gov, Regulations.gov, and others
# Register free at: https://api.data.gov/signup/
REGULATIONS_GOV_API_KEY=your_api_data_gov_key_here
GSA_PERDIEM_API_KEY=your_api_data_gov_key_here

# BLS (Bureau of Labor Statistics) — covers up to 500 requests/day (vs 25 anonymous)
# Register free at: https://api.bls.gov/registrationEngine/
BLS_API_KEY=your_bls_key_here

# API Base URLs (defaults work — only override if needed)
USASPENDING_BASE_URL=https://api.usaspending.gov/api/v2
FEDERAL_REGISTER_BASE_URL=https://www.federalregister.gov/api/v1
ECFR_BASE_URL=https://www.ecfr.gov/api/versioner/v1
BLS_BASE_URL=https://api.bls.gov/publicAPI/v2
REGULATIONS_GOV_BASE_URL=https://api.regulations.gov/v4

# Security (generate strong random values for staging/prod)
ENCRYPTION_KEY=generate-with-python-secrets-token-urlsafe-32

# App
ENVIRONMENT=dev
LOG_LEVEL=INFO
