# ═══════════════════════════════════════════════════════════
# Acquisition Copilot — Environment Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://acqcopilot:devpassword@localhost:5432/acqcopilot
DB_PASSWORD=devpassword

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LLM Providers (at least one required) ─────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# ── External API Keys ────────────────────────────────────
# BLS: Optional — enables higher rate limits
# Register at https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# Regulations.gov: Required for docket/document search
# Register at https://open.gsa.gov/api/regulationsgov/
REGULATIONS_GOV_API_KEY=

# ── API Base URLs (defaults are correct for production) ───
USASPENDING_BASE_URL=https://api.usaspending.gov/api/v2
FEDERAL_REGISTER_BASE_URL=https://www.federalregister.gov/api/v1
ECFR_BASE_URL=https://www.ecfr.gov/api
BLS_BASE_URL=https://api.bls.gov/publicAPI/v2
GSA_PERDIEM_BASE_URL=https://api.gsa.gov/travel/perdiem/v2
GSA_CALC_BASE_URL=https://calc.gsa.gov/api
REGULATIONS_GOV_BASE_URL=https://api.regulations.gov/v4

# ── Security ──────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Application ───────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
